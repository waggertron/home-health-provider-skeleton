{
  "name": "hhps-rt-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --enable-source-maps dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "ioredis": "5.4.1",
    "jsonwebtoken": "9.0.2",
    "ws": "8.18.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "20.14.12",
    "@types/ws": "8.5.13",
    "eslint": "9.13.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "typescript-eslint": "8.15.0",
    "vitest": "2.1.5"
  },
  "engines": {
    "node": ">=20 <21"
  }
}
